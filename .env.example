# 复制为 .env 并填入你的值（.env 已被 .gitignore，不会提交）

# ── worker：负责抽取 + 回答。唯一必需的 key。推荐 DeepSeek V4 Pro ──
KG_WORKER_API_KEY=your-worker-api-key
KG_WORKER_BASE_URL=https://api.deepseek.com/v1
KG_WORKER_MODEL=deepseek-chat

# ── 可选 API judge：仅“自治模式”给 reasoning 题判分用。必须不同于 worker ──
# 默认（agent 驱动模式）不需要它，留空即可。
KG_JUDGE_API_KEY=
KG_JUDGE_BASE_URL=
KG_JUDGE_MODEL=

# ── Neo4j（首次使用前先执行一次 schema/constraints.cypher 建库）──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ── 日志级别（可选：DEBUG/INFO/WARNING）──
KG_LOG_LEVEL=INFO
